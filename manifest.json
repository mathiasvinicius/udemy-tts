{
  "manifest_version": 3,
  "name": "Udemy Transcript TTS (Free)",
  "description": "Reads Udemy captions/transcript in real time using the browser's built-in voices.",
  "version": "0.1.56",
  "icons": {
    "16": "icon/icon16.png",
    "32": "icon/icon32.png",
    "48": "icon/icon48.png",
    "128": "icon/icon128.png"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://*.udemy.com/*"
  ],
  "action": {
    "default_title": "Udemy Transcript TTS",
    "default_icon": {
      "16": "icon/icon16.png",
      "32": "icon/icon32.png",
      "48": "icon/icon48.png",
      "128": "icon/icon128.png"
    },
    "default_popup": "popup.html"
  },
  "options_page": "config.html",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.udemy.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}

